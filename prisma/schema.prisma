generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HeroSlide {
  id           String    @id @default(cuid())
  type         MediaType @default(IMAGE)
  mediaUrl     String
  storagePath  String
  title        String?
  subtitle     String?
  ctaText      String?
  ctaLink      String?
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
}

model ClientLogo {
  id           String   @id @default(cuid())
  name         String
  imageUrl     String
  storagePath  String
  displayOrder Int      @default(0)
  isVisible    Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model Service {
  id                 String   @id @default(cuid())
  type               String   @default("MAIN")
  icon               String
  name               String
  slug               String   @unique
  description        String
  heroHeadline       String?
  heroSubtitle       String?
  whatWeDo           String?
  signatureEvents    String?
  differentiators    String?
  faqs               String?
  coverImageUrl      String?
  storagePath        String?
  displayOrder       Int      @default(0)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  metaDescription    String?
  metaKeywords       String?
  metaTitle          String?
  linkedPortfolioIds String?
  seoContent         String?
}

model BlogPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  content         String
  excerpt         String?
  coverImageUrl   String?
  storagePath     String?
  category        String?
  tags            String?
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  wpId            Int?      @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  metaDescription String?
  metaKeywords    String?
  metaTitle       String?
}

model PortfolioItem {
  id           String   @id @default(cuid())
  title        String?
  category     String
  imageUrl     String
  storagePath  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PortfolioEvent {
  id              String           @id @default(cuid())
  title           String
  slug            String           @unique
  description     String?
  category        String
  clientName      String?
  eventDate       DateTime?
  coverImageUrl   String?
  displayOrder    Int              @default(0)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  metaDescription String?
  metaKeywords    String?
  metaTitle       String?
  featuredOnHome  Boolean          @default(false)
  media           PortfolioMedia[]
}

model PortfolioMedia {
  id           String         @id @default(cuid())
  eventId      String
  type         String         @default("IMAGE")
  url          String
  storagePath  String?
  displayOrder Int            @default(0)
  createdAt    DateTime       @default(now())
  event        PortfolioEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model PageSeo {
  id              String   @id @default(cuid())
  pageKey         String   @unique
  pageLabel       String
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CareerApplication {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String
  position        String
  experience      String
  currentRole     String?
  message         String?
  resumeUrl       String?
  status          String   @default("NEW")
  createdAt       DateTime @default(now())
  currentCompany  String?
  currentLocation String?
}

model Quote {
  id              String      @id @default(cuid())
  name            String
  email           String
  phoneCode       String      @default("+91")
  phone           String
  company         String
  location        String
  teamSize        String?
  targetAudiences String?
  preferredDate   String?
  typeOfProgram   String?
  budget          String?
  howDidYouHear   String?
  status          QuoteStatus @default(NEW)
  contactedAt     DateTime?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  isArchived      Boolean     @default(false)
}

model YoutubeVideo {
  id           String   @id @default(cuid())
  youtubeId    String
  title        String
  serviceSlug  String?
  showOnHome   Boolean  @default(true)
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  serviceSlugs String?
}

model ClientFeedback {
  id           String   @id @default(cuid())
  service      Int
  timeline     Int
  appreciation Int
  referral     Int
  experience   String?
  submittedAt  DateTime @default(now())
  email        String?
  name         String
}

enum MediaType {
  IMAGE
  VIDEO
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

enum QuoteStatus {
  NEW
  CONTACTED
  CLOSED
}
